<Window x:Class="MpImporter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:MpImporter.ViewModels"
        mc:Ignorable="d"
        Title="MP Importer" Height="600" Width="980"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <!-- Toolbar -->
        <ToolBar DockPanel.Dock="Top" Height="40">
            <Button Content="Add Files" Command="{Binding AddFilesCommand}"
                    Padding="12,4" Margin="4,0"/>
            <Separator/>
            <Button Content="Batch Extract" Command="{Binding BatchExtractCommand}"
                    Padding="12,4" Margin="4,0"/>
            <Button Content="Remove Selected" Command="{Binding RemoveSelectedCommand}"
                    Padding="12,4" Margin="4,0"/>
            <Separator/>
            <Button Content="Upload Data" Command="{Binding UploadDataCommand}"
                    Padding="12,4" Margin="4,0"/>
        </ToolBar>

        <!-- File list header -->
        <Grid DockPanel.Dock="Top" Height="28" Background="#F0F0F0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="36"/>
                <ColumnDefinition Width="48"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="1" Text="No." VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="SemiBold"/>
            <TextBlock Grid.Column="2" Text="File Name" VerticalAlignment="Center" Margin="8,0" FontWeight="SemiBold"/>
            <TextBlock Grid.Column="3" Text="Open" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="SemiBold"/>
            <TextBlock Grid.Column="4" Text="Extract" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="SemiBold"/>
            <TextBlock Grid.Column="5" Text="View Results" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="SemiBold"/>
            <TextBlock Grid.Column="6" Text="Remove" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="SemiBold"/>
        </Grid>

        <!-- File list (drop target) -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      AllowDrop="True"
                      DragOver="FileList_DragOver"
                      Drop="FileList_Drop">
            <ItemsControl ItemsSource="{Binding FileEntries}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
                            <Grid Height="36">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="48"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>

                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding IsChecked}"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Center"/>

                                <TextBlock Grid.Column="1"
                                           Text="{Binding Index}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           Foreground="#888"/>

                                <TextBlock Grid.Column="2"
                                           Text="{Binding FileName}"
                                           VerticalAlignment="Center"
                                           Margin="8,0"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding FilePath}"/>

                                <Button Grid.Column="3"
                                        Content="Open"
                                        Command="{Binding OpenFileCommand}"
                                        Margin="4" Padding="6,2"/>

                                <Button Grid.Column="4"
                                        Content="Extract"
                                        Command="{Binding ExtractCommand}"
                                        Margin="4" Padding="6,2"/>

                                <Button Grid.Column="5"
                                        Content="View Results"
                                        Command="{Binding ViewResultsCommand}"
                                        Margin="4" Padding="6,2"/>

                                <Button Grid.Column="6"
                                        Content="Remove"
                                        Command="{Binding RemoveCommand}"
                                        Margin="4" Padding="6,2"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>
