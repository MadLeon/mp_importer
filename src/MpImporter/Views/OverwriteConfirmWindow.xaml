<Window x:Class="MpImporter.Views.OverwriteConfirmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Process Template Already Exists"
        Height="500" Width="780"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">
    <DockPanel Margin="12">

        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
            <TextBlock FontSize="14" FontWeight="SemiBold">
                <Run Text="Drawing: "/>
                <Run Text="{Binding DrawingNumber}"/>
                <Run Text="   Rev: "/>
                <Run Text="{Binding Revision}"/>
            </TextBlock>
            <TextBlock Foreground="#666" Margin="0,2,0,0"
                       Text="A process template already exists for this part. Review the differences and choose an action."/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Overwrite" Width="90" Height="32" Margin="0,0,8,0"
                    Click="Overwrite_Click"/>
            <Button Content="Skip" Width="90" Height="32"
                    Click="Skip_Click"/>
        </StackPanel>

        <!-- Side-by-side comparison -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Existing -->
            <DockPanel Grid.Column="0">
                <TextBlock DockPanel.Dock="Top" Text="Current (Database)"
                           FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox Text="{Binding ExistingText, Mode=OneWay}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         FontFamily="Consolas" FontSize="12"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         Background="#F8F8F8"/>
            </DockPanel>

            <!-- New -->
            <DockPanel Grid.Column="2">
                <TextBlock DockPanel.Dock="Top" Text="New (Extracted)"
                           FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox Text="{Binding NewText, Mode=OneWay}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         FontFamily="Consolas" FontSize="12"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         Background="#F0FFF0"/>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
